do
	local main = nil
	if root:IsA("Frame") and root.Name == "Main" then
		main = root
	else
		local candidate = root:FindFirstChild("Main")
		if candidate and candidate:IsA("Frame") then
			main = candidate
		end
	end

	if main and main:FindFirstChild("Topbar") and main:FindFirstChild("Sidebar") and main:FindFirstChild("BottomBar") and not main:FindFirstChild("ThemeImage") then
		local themeImage = Instance.new("ImageLabel")
		themeImage.Name = "ThemeImage"
		themeImage.Active = false
		themeImage.AnchorPoint = Vector2.new(0, 0)
		themeImage.AutomaticSize = Enum.AutomaticSize.None
